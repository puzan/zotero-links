{
  "manifest_version": 2,
  "name": "Zotero Collection Links",
  "version": "0.1.0",
  "description": "Copy zotero:// links for collections via right-click menu",
  "author": "",
  "applications": {
    "zotero": {
      "id": "zotero-collection-links@local",
      "update_url": "https://localhost:8443/",
      "strict_min_version": "7.0",
      "strict_max_version": "8.*"
    }
  }
}
